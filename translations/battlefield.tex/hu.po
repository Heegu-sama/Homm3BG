"        \\begin{relcoords}{card}\n"
"          \\draw (0.7, 0.85) node {\\encirclesmall{1}};\n"
"          \\draw (0.6, 0.4) node {\\encirclesmall{2}};\n"
"          \\draw (0.2, 0.2) node {\\encirclesmall{3}};\n"
"        \\end{relcoords}\n"
"      \\end{tikzpicture}\n"
"      \\imagecaption{Adventure-Event card}\\index{Event cards (Adventure)}\n"
"      \\begin{enumerate}\n"
"        \\item[\\textbf{1.}] Name\n"
"        \\item[\\textbf{2.}] Type\n"
"        \\item[\\textbf{3.}] Effect\n"
"      \\end{enumerate}\n"
"    \\end{center}\n"
"    \\columnbreak\n"
"\n"
msgstr ""
"        \\node (card) [inner sep=0] {\\includegraphics[width=\\linewidth]{\\cards/adventure_event.png}};\n"
"        \\begin{relcoords}{card}\n"
"          \\draw (0.7, 0.85) node {\\encirclesmall{1}};\n"
"          \\draw (0.6, 0.4) node {\\encirclesmall{2}};\n"
"          \\draw (0.2, 0.2) node {\\encirclesmall{3}};\n"
"        \\end{relcoords}\n"
"      \\end{tikzpicture}\n"
"      \\imagecaption{Kaland-Esemény kártya}\\index{Event cards (Adventure)}\n"
"      \\begin{enumerate}\n"
"        \\item[\\textbf{1.}] Név\n"
"        \\item[\\textbf{2.}] Típus\n"
"        \\item[\\textbf{3.}] Hatás\n"
"      \\end{enumerate}\n"
"    \\end{center}\n"
"    \\columnbreak\n"
"\n"

