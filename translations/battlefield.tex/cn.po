"        \\lightcell[1.2]{等级VII} \\\\\n"
"        \\darkcell[1.2]{特长牌} &\n"
"        \\lightcell[1.2]{等级I\\\\特长牌} &\n"
"        \\lightcell[1.2]{等级I和\\\\等级IV特长牌} &\n"
"        \\lightcell[1.2]{所有特长牌} \\\\\n"
"        \\darkcell[1.8]{能力牌} &\n"
"        \\lightcell[1.8]{抽3张能力牌，保留2张。} &\n"
"        \\lightcell[1.8]{抽4张能力牌，保留3张。} &\n"
"        \\lightcell[1.8]{抽6张能力牌，保留4张。} \\\\\n"
"        \\darkcell[1.8]{神器牌} &\n"
"        \\lightcell[1.8]{抽2张神器牌，保留1张。} &\n"
"        \\lightcell[1.8]{抽3张神器牌，保留2张。} &\n"
"        \\lightcell[1.8]{抽4张神器牌，保留3张。} \\\\\n"
"        \\darkcell[2.2]{法术牌} &\n"
"        \\lightcell[2.2]{为\\svg[12]{might-yellow}英雄抽1张法术牌，或为\\svg{magic-yellow}英雄抽2张法术牌。} &\n"
"        \\lightcell[2.2]{为\\svg[12]{might-yellow}英雄抽2张法术牌，或为\\svg{magic-yellow}英雄抽4张法术牌。} &\n"
"        \\lightcell[2.2]{为\\svg[12]{might-yellow}英雄抽3张法术牌，或为\\svg{magic-yellow}英雄抽5张法术牌。} \\\\\n"
"        \\darkcell[2.2]{单位} &\n"
"        \\lightcell[2.2]{使用所有\\svg{bronze}和\\svg{silver}单位的“少量”面。} &\n"
"        \\lightcell[2.2]{使用所有\\svg{bronze}和\\svg{silver}单位的“一群”面。} &\n"
"        \\lightcell[2.2]{使用所有单位（\\svg{bronze}、\\svg{silver}和\\svg{golden}）的“一群”面。} \\\\\n"
