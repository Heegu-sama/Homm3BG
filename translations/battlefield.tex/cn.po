"  \\pagetarget{Adventure Cards}{\\subsection*{处理冒险牌}}\n"
"  冒险牌有两种类型：战斗和事件。\n"
"  \\medskip\n"
"  \\begin{multicols*}{2}\n"
"    \\footnotesize\n"
"    \\begin{center}\n"
