#. type: multicols
#: sections/all_map_locations.tex:264
#, no-wrap
msgid ""
"\\pagetarget{Mines}{\\subheader{Mines}}\n"
"{\\textbf{Mines}}\\index{Mines} are flaggable Fields which increase a specific resource's income when flagged.\n"
"If you are the first one to flag a mine, it also immediately provides you with its income.\n"
"All mines have the \\svg{ongoing} symbol and a picture of the Resource they produce next to it.\n"
"\n"
msgstr ""
"\\pagetarget{Mines}{\\subheader{Bányák}}\n"
"{\\textbf{A Bányák}}\\index{Bányák} olyan megjelölhető Mezők, amelyek megjelölés esetén növelik egy adott erőforrás bevételét.\n"
"Ha elsőként jelölsz meg egy bányát, az azonnal meg is adja neked a termelését.\n"
"Minden bányán szerepel a \\svg{ongoing} szimbólum és mellette annak az Erőforrásnak a képe, amelyet termel.\n"
"\n"

#. type: multicols
#: sections/all_map_locations.tex:270
#, no-wrap
msgid ""
"\\begin{center}\n"
"  \\includegraphics[width=0.55\\linewidth]{\\images/mine_example.png}\\\\\n"
"  \\textit{A mine that produces \\svg{valuables}, guarded by \\mbox{Level III} Neutral Units.\n"
"    The first player to flag this Field would immediately gain one \\svg{valuables} in addition to increasing their \\svg{valuables} income.\n"
"  }\n"
"\n"
msgstr ""
"\\begin{center}\n"
"  \\includegraphics[width=0.55\\linewidth]{\\images/mine_example.png}\\\\\n"
"  \\textit{Egy \\svg{valuables} termelő bánya, amelyet \\mbox{III. szintű} Semleges Egységek őriznek.\n"
"    Az első játékos, aki megjelöli ezt a Mezőt, azonnal kap egy \\svg{valuables} erőforrást amellett, hogy növekszik a \\svg{valuables} bevétele.\n"
"  }\n"
"\n"

