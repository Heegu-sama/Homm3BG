#. type: multicols*
#: sections/all_map_locations.tex:49
#, no-wrap
msgid ""
"\\begin{itemize}[itemsep=0.4em]\n"
"  \\item [{\\LARGE$\\boldsymbol{+}$}]\n"
"    \\svg{gold}$\\boldsymbol{/}$\\svg{building_materials}$\\boldsymbol{/}$\\svg{valuables} —\n"
"    Immediately gain the indicated Resource.\n"
"  \\item [{\\svg[14]{ongoing}}]\n"
"    \\svg{gold}$\\boldsymbol{/}$\\svg{building_materials}$\\boldsymbol{/}$\\svg{valuables} —\n"
"    Increase the production of the indicated Resource.\n"
"    If it is \\textbf{flagged} for the first time, you also gain it immediately. See \\pagelink{Mines}{Mines}.\n"
"  \\item [{\\svg[10]{pay}}]\n"
"    \\svg{gold}$\\boldsymbol{/}$\\svg{building_materials}$\\boldsymbol{/}$\\svg{valuables} \\svg{arrow_right} —\n"
"    The Player needs to pay the indicated Resource to gain something.\n"
"  \\item [{\\LARGE\\textbf{2}}] {\\LARGE\\textbf{x}} —\n"
"    Perform the {\\LARGE\\textbf{x}} action twice.\n"
"  \\item [{\\LARGE\\textbf{2}}] \\svg[14]{treasure}{\\LARGE\\textbf{$\\boldsymbol{/}$2}} \\svg[14]{resource_die} \\svg{arrow_right}{\\LARGE\\textbf{1}} —\n"
"    Roll 2 Treasure or Resource Dice and resolve one,\n"
"    OR draw \\pagelink{Pandora Card}{Pandora's Box card}.\n"
"\\end{itemize}\n"
"\n"
msgstr ""
"\\begin{itemize}[itemsep=0.4em]\n"
"  \\item [{\\LARGE$\\boldsymbol{+}$}]\n"
"    \\svg{gold}$\\boldsymbol{/}$\\svg{building_materials}$\\boldsymbol{/}$\\svg{valuables} —\n"
"    Отримайте вказаний Ресурс.\n"
"  \\item [{\\svg[14]{ongoing}}]\n"
"    \\svg{gold}$\\boldsymbol{/}$\\svg{building_materials}$\\boldsymbol{/}$\\svg{valuables} —\n"
"    Збільшіть виробництво вказаного Ресурсу.\n"
"    Якщо цей Ресурс \\textbf{захоплено} вперше, на додаток отримайте його одразу. Дивись \\pagelink{Mines}{Копальні}.\n"
"  \\item [{\\svg[10]{pay}}]\n"
"    \\svg{gold}$\\boldsymbol{/}$\\svg{building_materials}$\\boldsymbol{/}$\\svg{valuables} \\svg{arrow_right} —\n"
"    Гравець має заплатити вказаний Ресурс, щоб отримати щось.\n"
"  \\item [{\\LARGE\\textbf{2}}] {\\LARGE\\textbf{x}} —\n"
"    Виконайте дію {\\LARGE\\textbf{x}} двічі.\n"
"  \\item [{\\LARGE\\textbf{2}}] \\svg[14]{treasure}{\\LARGE\\textbf{$\\boldsymbol{/}$2}} \\svg[14]{resource_die} \\svg{arrow_right}{\\LARGE\\textbf{1}} —\n"
"    Киньте 2 Кубики Скарбів або Ресурсів і виберіть одну з нагород,\n"
"    АБО візьміть \\pagelink{Pandora Card}{карту Скриньки Пандори}.\n"
"\\end{itemize}\n"
"\n"

