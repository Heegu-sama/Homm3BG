"  \\framedimage[\\linewidth]{\\map_locations/ore-gold-mine.jpg}\n"
"  \\textit{\\svg{building_materials} and \\svg{gold} mines.}\n"
"\\end{center}"
msgstr ""
"  \\vspace*{\\fill}\n"
"  \\framedimage[\\linewidth]{\\map_locations/ore-gold-mine.jpg}\n"
"  \\textit{\\svg{building_materials} і \\svg{gold} копальні.}\n"
"\\end{center}"

