#. type: expansion
#: sections/card_effect_keywords.tex:157
#, no-wrap
msgid ""
"  \\vspace*{1em}\n"
"  \\pagetarget{Force Field Token}{\\subsection*{Force Field Token}}\n"
"  \\index{Force Field}\n"
"  \\setlength\\intextsep{0pt}\n"
"  \\setlength\\columnsep{1em}\n"
"  \\begin{wrapfigure}{r}{0.25\\linewidth}\n"
"    \\includegraphics[width=\\linewidth]{\\images/force-field-token.png}\n"
"    \\begin{center}\n"
"      \\imagecaption{Force Field Token}\\\\\n"
"      \\vspace*{1em}\n"
"    \\end{center}\n"
"  \\end{wrapfigure}\n"
"  Use the \\textbf{Force Field Token} to mark the effect of the \\wikilink{spells/force_field}{\\textbf{Force Field Spell}.}\n"
"  The Token represents an Obstacle, so only \\svg{unit_flying} units can move through a space with this Token.\n"
"  If you're using the normal Combat Board, place 1 Force Field Token.\n"
"  If you're using the \\pagelink{Battlefield Combat}{Battlefield Board}, place 2 Tokens on two adjacent spaces.\n"
"\\begin{center}\n"
"  {\\hspace{2em}\\transparent{0.2}\\includegraphics[width=0.5\\linewidth]{\\art/land_mine.png}}\n"
"\\end{center}"
msgstr ""
"  \\vspace*{1em}\n"
"  \\pagetarget{Force Field Token}{\\subsection*{Żeton Pola Mocy}}\n"
"  \\index{Pole Mocy}\n"
"  \\setlength\\intextsep{0pt}\n"
"  \\setlength\\columnsep{1em}\n"
"  \\begin{wrapfigure}{r}{0.25\\linewidth}\n"
"    \\includegraphics[width=\\linewidth]{\\images/force-field-token.png}\n"
"    \\begin{center}\n"
"      \\imagecaption{Żeton Pola Mocy}\\\\\n"
"      \\vspace*{1em}\n"
"    \\end{center}\n"
"  \\end{wrapfigure}\n"
"  Użyj \\textbf{Żetonu Pola Mocy}, aby oznaczyć efekt Zaklęcia \\wikilink{spells/force_field}{\\textbf{Pola Mocy}}.\n"
"  Żeton oznacza Przeszkodę, więc tylko jednostki \\svg{unit_flying} mogą przemieszczać się przez pole z tym Żetonem.\n"
"  Jeśli korzystasz ze zwykłej Planszy Walki, umieść 1 Żeton Pola Mocy.\n"
"  Jeśli korzystasz z \\pagelink{Battlefield Combat}{Pola Bitwy}, umieść 2 Żetony na dwóch sąsiednich polach.\n"
"\\begin{center}\n"
"  {\\hspace{2em}\\transparent{0.2}\\includegraphics[width=0.5\\linewidth]{\\art/land_mine.png}}\n"
"\\end{center}"

