#. type: Plain text
#: sections/card_effect_keywords.tex:263
msgid ""
"The following components and keywords are used by certain unit abilities.  "
"These Tokens are typically placed on other units to modify their statistics."
msgstr ""
"Poniższe komponenty i słowa kluczowe są wykorzystywane przez zdolności "
"niektórych jednostek.  Żetony te są zazwyczaj umieszczane na innych "
"jednostkach, aby modyfikować ich statystyki."

#. type: multicols
#: sections/card_effect_keywords.tex:263
#, no-wrap
msgid ""
"{2}\n"
"  \\begin{expansion}{cove,stretchgoals2}\n"
"    \\pagetarget{Weakness Token}{\\subsection*{Weakness Token}}\n"
"    \\index{Weakness Token}\n"
"    \\setlength\\intextsep{0pt}\n"
"    \\setlength\\columnsep{1em}\n"
"    \\begin{wrapfigure}{r}{0.25\\linewidth}\n"
"      \\centering\n"
"      \\includegraphics[width=0.8\\linewidth]{\\images/weakness-token.png}\\\\\n"
"      \\imagecaption{Weakness Token}\\\\\n"
"      \\vspace{1em}\n"
"    \\end{wrapfigure}\n"
"    \\textbf{\\wikilink{units/sorceresses/\\#few}{``Few'' Sorceresses}} unit from the Cove Faction can use their \\svg{unit_alternative} ability to place a Weakness Token on any unit.  % enemy unit?\n"
"    A~\\wikilink{units/sorceresses/\\#pack}{\\textbf{``Pack'' of Sorceresses}} places this Token automatically on a unit attacked by them due to their \\svg{unit_attack} ability.\n"
"    A unit with this Token suffers $-1$~\\svg{attack} or $-2$~\\svg{attack}, as indicated by the Token's side.\n"
"    Each unit can have only one Weakness Token at a time.\n"
"    If a unit would gain a second one, the player controlling it chooses which one to keep.\n"
"    \\begin{center}\n"
"      \\vspace*{2.5em}\n"
"      {\\transparent{0.2}\\includegraphics[width=0.9\\linewidth]{\\art/weakness.png}}\n"
"      \\vspace*{2em}\n"
"    \\end{center}\n"
"  \\end{expansion}\n"
"  \\columnbreak\n"
"\n"
msgstr ""
"{2}\n"
"  \\begin{expansion}{cove,stretchgoals2}\n"
"    \\pagetarget{Weakness Token}{\\subsection*{Żeton Osłabienia}}\n"
"    \\index{Żeton!Osłabienia}\n"
"    \\setlength\\intextsep{0pt}\n"
"    \\setlength\\columnsep{1em}\n"
"    \\begin{wrapfigure}{r}{0.25\\linewidth}\n"
"      \\centering\n"
"      \\includegraphics[width=0.8\\linewidth]{\\images/weakness-token.png}\\\\\n"
"      \\imagecaption{Żeton Osłabienia}\\\\\n"
"      \\vspace{1em}\n"
"    \\end{wrapfigure}\n"
"    Jednostka \\textbf{\\wikilink{units/sorceresses/\\#few}{,,Garstki'' Czarodziejek}} z frakcji Przystani może użyć swojej zdolności \\svg{unit_alternative}, aby umieścić Żeton Osłabienia na dowolnej jednostce.  % enemy unit?\n"
"    \\wikilink{units/sorceresses/\\#pack}{\\textbf{,,Grupa'' Czarodziejek}} umieszcza ten Żeton automatycznie na jednostce zaatakowanej przez nie dzięki ich zdolności \\svg{unit_attack}.\n"
"    Jednostka z tym Żetonem otrzymuje $-1$~\\svg{attack} lub $-2$~\\svg{attack}, w zależności od strony Żetonu.\n"
"    Każda jednostka może mieć tylko jeden Żeton Osłabienia naraz.\n"
"    Jeśli jednostka miałaby otrzymać drugi, gracz ją kontrolujący wybiera, który z nich zatrzymać.\n"
"    \\begin{center}\n"
"      \\vspace*{2.5em}\n"
"      {\\transparent{0.2}\\includegraphics[width=0.9\\linewidth]{\\art/weakness.png}}\n"
"      \\vspace*{2em}\n"
"    \\end{center}\n"
"  \\end{expansion}\n"
"  \\columnbreak\n"
"\n"

#. type: multicols
#: sections/card_effect_keywords.tex:280
#, no-wrap
msgid ""
"  \\begin{expansion}{stronghold,stretchgoals2}\n"
"    \\pagetarget{Attack Token}{\\subsection*{Attack Token}}\n"
"    \\index{Attack Token}\n"
"    \\setlength\\intextsep{0pt}\n"
"    \\setlength\\columnsep{1em}\n"
"    \\begin{wrapfigure}{r}{0.2\\linewidth}\n"
"      \\centering\n"
"      \\includegraphics[width=\\linewidth]{\\images/attack-token.png}\\\\\n"
"      \\imagecaption{Attack Token}\\\\\n"
"      \\vspace{1em}\n"
"    \\end{wrapfigure}\n"
"    The \\textbf{\\wikilink{units/ogres}{Ogres}} unit from the Stronghold Faction can use their \\svg{unit_alternative} ability to place Attack Tokens on other allied unit cards.\n"
"    Units with such a Token gain an additional 1~\\svg{attack} or 2~\\svg{attack}, as indicated by the Token's side.\n"
"    Each unit can have only one Attack Token at a time.\n"
"    If a unit would gain a second one, the player controlling it chooses which one to keep.\n"
"  \\end{expansion}\n"
"\n"
msgstr ""
"  \\begin{expansion}{stronghold,stretchgoals2}\n"
"    \\pagetarget{Attack Token}{\\subsection*{Żeton Ataku}}\n"
"    \\index{Żeton!Ataku}\n"
"    \\setlength\\intextsep{0pt}\n"
"    \\setlength\\columnsep{1em}\n"
"    \\begin{wrapfigure}{r}{0.2\\linewidth}\n"
"      \\centering\n"
"      \\includegraphics[width=\\linewidth]{\\images/attack-token.png}\\\\\n"
"      \\imagecaption{Żeton Ataku}\\\\\n"
"      \\vspace{1em}\n"
"    \\end{wrapfigure}\n"
"    Jednostka \\textbf{\\wikilink{units/ogres}{Ogrów}} z frakcji Twierdzy może użyć swojej zdolności \\svg{unit_alternative}, aby umieścić Żetony Ataku na kartach innych przyjaznych jednostek.\n"
"    Jednostki z takim Żetonem zyskują dodatkowe 1~\\svg{attack} lub 2~\\svg{attack}, w zależności od strony Żetonu.\n"
"    Każda jednostka może mieć tylko jeden Żeton Ataku naraz.\n"
"    Jeśli jednostka miałaby otrzymać drugi, gracz ją kontrolujący wybiera, który z nich zatrzymać.\n"
"  \\end{expansion}\n"
"\n"

#. type: multicols
#: sections/card_effect_keywords.tex:299
#, no-wrap
msgid ""
"  \\vspace*{1em}\n"
"  \\begin{expansion}{stronghold}\n"
"    \\pagetarget{Corrosion Token}{\\subsection*{Corrosion Token}}\n"
"    \\index{Corrosion Token}\n"
"    \\setlength\\intextsep{0pt}\n"
"    \\setlength\\columnsep{1em}\n"
"    \\begin{wrapfigure}{r}{0.25\\linewidth}\n"
"      \\centering\n"
"      \\includegraphics[width=0.8\\linewidth]{\\images/corrosion-token.png}\\\\\n"
"      \\imagecaption{Corrosion Token}\\\\\n"
"      \\vspace{1em}\n"
"    \\end{wrapfigure}\n"
"    The \\textbf{\\wikilink{units/behemoths}{Behemoths}} unit from the Stronghold Faction can use their \\svg{unit_attack} ability to place a Corrosion Token on a unit attacked by them.\n"
"    It reduces the enemy's unit \\svg{defense} by 1 to a minimum of 0.\n"
"    A unit can have only one Corrosion Token at a time.\n"
"    If a unit would gain a second Token, discard one of them.\n"
"    Unless removed by Spells or other effects, a Corrosion Token remains on the unit until the end of Combat.\n"
"  \\end{expansion}"
msgstr ""
"  \\vspace*{1em}\n"
"  \\begin{expansion}{stronghold}\n"
"    \\pagetarget{Corrosion Token}{\\subsection*{Żeton Korozji}}\n"
"    \\index{Żeton!Korozji}\n"
"    \\setlength\\intextsep{0pt}\n"
"    \\setlength\\columnsep{1em}\n"
"    \\begin{wrapfigure}{r}{0.25\\linewidth}\n"
"      \\centering\n"
"      \\includegraphics[width=0.8\\linewidth]{\\images/corrosion-token.png}\\\\\n"
"      \\imagecaption{Żeton Korozji}\\\\\n"
"      \\vspace{1em}\n"
"    \\end{wrapfigure}\n"
"    Jednostka \\textbf{\\wikilink{units/behemoths}{Behemotów}} z frakcji Twierdzy może użyć swojej zdolności \\svg{unit_attack}, aby umieścić Żeton Korozji na zaatakowanej przez nią jednostce.\n"
"    Zmniejsza on \\svg{defense} wrogiej jednostki o 1, do minimum 0.\n"
"    Jednostka może mieć tylko jeden Żeton Korozji naraz.\n"
"    Jeśli jednostka miałaby otrzymać drugi Żeton, odrzuć jeden z nich.\n"
"    Żeton Korozji pozostaje na jednostce do końca Walki, o ile nie zostanie usunięty przez Zaklęcia lub inne efekty.\n"
"  \\end{expansion}"

