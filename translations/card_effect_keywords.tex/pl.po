#. type: multicols
#: sections/card_effect_keywords.tex:72
#, no-wrap
msgid ""
"{2}\n"
"\\begin{expansion}{stronghold}\n"
"  \\pagetarget{Quicksand Token}{\\subsection*{Quicksand Token}}\n"
"  \\index{Quicksand}\n"
"  While casting the \\wikilink{spells/quicksand}{\\textbf{Quicksand Spell},} depending on the \\svg{empower} used, take 2, 4 or 6 \\textbf{Quicksand Tokens} from the same set (blue or red).\n"
"  Half of them must be ``empty'' and half must have the Quicksand symbol.\n"
"  Shuffle the Tokens face down and place one on each chosen empty space on the Combat Board.\n"
"  If there are not enough empty spaces to place all of them, discard any leftover Tokens.\n"
"  Once placed, you may look at your Tokens at any time.\n"
"  When a unit enters a space with a Quicksand Token, reveal it.\n"
"  If it is empty, the unit continues its movement.\n"
"  If the Token shows the Quicksand icon, the unit's movement and activation end immediately.\n"
"\n"
msgstr ""
"{2}\n"
"\\begin{expansion}{stronghold}\n"
"  \\pagetarget{Quicksand Token}{\\subsection*{Żeton Ruchomych Piasków}}\n"
"  \\index{Ruchome Piaski}\n"
"  Rzucając Zaklęcie \\wikilink{spells/quicksand}{\\textbf{Ruchomych Piasków}}, w zależności od użytego \\svg{empower}, weź 2, 4 lub 6 \\textbf{Żetonów Ruchomych Piasków} w tym samym kolorze (niebieskim lub czerwonym).\n"
"  Połowa z nich musi być ,,pusta'', a połowa musi mieć symbol Ruchomych Piasków.\n"
"  Potasuj Żetony i umieść zakryte po jednym na wybranych pustych polach Planszy Walki.\n"
"  Jeśli nie ma wystarczającej liczby pustych pól, odrzuć nadmiarowe Żetony.\n"
"  Po umieszczeniu możesz w dowolnym momencie podglądać swoje Żetony.\n"
"  Gdy jednostka wchodzi na pole z Żetonem Ruchomych Piasków, odkryj go.\n"
"  Jeśli jest pusty, jednostka kontynuuje ruch.\n"
"  Jeśli Żeton pokazuje ikonę Ruchomych Piasków, ruch i aktywacja jednostki natychmiast się kończą.\n"
"\n"

#. type: multicols
#: sections/card_effect_keywords.tex:79
#, no-wrap
msgid ""
"  \\textbf{Note:} Two Quicksand Tokens may occupy a single space only if they are placed by different players.\n"
"  \\bigskip\n"
"  \\begin{multicols*}{2}\n"
"    \\centering\n"
"    \\includegraphics[width=0.5\\linewidth]{\\images/quicksand-token.png}\\\\\n"
"    \\imagecaption{Quicksand Token}\n"
"\n"
msgstr ""
"  \\textbf{Uwaga:} Dwa Żetony Ruchomych Piasków mogą zajmować jedno pole tylko wtedy, gdy zostały umieszczone przez różnych graczy.\n"
"  \\bigskip\n"
"  \\begin{multicols*}{2}\n"
"    \\centering\n"
"    \\includegraphics[width=0.5\\linewidth]{\\images/quicksand-token.png}\\\\\n"
"    \\imagecaption{Żeton Ruchomych Piasków}\n"
"\n"

