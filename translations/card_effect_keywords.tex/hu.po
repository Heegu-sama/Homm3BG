"    \\centering\n"
"    \\includegraphics[width=0.5\\linewidth]{\\images/quicksand-token.png}\\\\\n"
"    \\imagecaption{Quicksand Token}\n"
"\n"
msgstr ""
"  \\textbf{Megjegyzés:} Két Futóhomok jelző csak akkor lehet ugyanazon a helyen, ha különböző játékosok helyezték le őket.\n"
"  \\bigskip\n"
"  \\begin{multicols*}{2}\n"
"    \\centering\n"
"    \\includegraphics[width=0.5\\linewidth]{\\images/quicksand-token.png}\\\\\n"
"    \\imagecaption{Futóhomok jelző}\n"
"\n"

