#. type: multicols
#: sections/card_effect_keywords.tex:95
#, no-wrap
msgid ""
"\\vspace*{1em}\n"
"\\begin{expansion}{battlefield,conflux}\n"
"  \\pagetarget{Fire Wall Token}{\\subsection*{Fire Wall Token}}\n"
"  \\index{Fire Wall}\n"
"  The \\wikilink{spells/fire_wall}{\\textbf{Fire Wall Spell}} and \\wikilink{h"
"eroes/luna\\#specialty}{\\textbf{Luna's Specialty cards I and VI}} instruct yo"
"u to place the Fire Wall card onto a space on the Combat Board.\n"
"  You may use the Fire Wall Tokens instead of the cards.\n"
"  Place the Spell or Specialty card next to the Combat Board as a reminder.\n"
"  When the card is removed or discarded, discard the Token as well.\n"
"  When using the large \\pagelink{Battlefield Combat}{Battlefield Board}, you "
"must use the Token instead of the card.\n"
"\n"
msgstr ""
"\\vspace*{1em}\n"
"\\begin{expansion}{battlefield,conflux}\n"
"  \\pagetarget{Fire Wall Token}{\\subsection*{Жетон огненной стены}}\n"
"  \\index{Огненная стена}\\index{Стена огненная}\n"
"  Заклинание \\wikilink{spells/fire_wall}{\\textbf{Огненной стены}} и \\wikili"
"nk{heroes/luna\\#specialty}{\\textbf{специальности Луны I и VI}} говорят вам п"
"оместить карту огненной стены на клетку на доске сражений.\n"
"  Вместо карт вы можете использовать жетоны,\n"
"  при этом для напоминания поместите карту заклинания или специальности рядом "
"с доской.\n"
"  Когда карта удалена или скинута, уберите жетон.\n"
"  При использовании большой \\pagelink{Battlefield Combat}{доски Battlefield} "
"необходимо использовать жетоны.\n"
"\n"

