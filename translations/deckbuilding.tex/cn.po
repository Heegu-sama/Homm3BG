"        \\draw (0.6, 0.92) node {\\encircle{1}};\n"
"        \\draw (0.5, 0.15) node {\\encircle{2}};\n"
"        \\draw (0.3, 0.3) node {\\encircle{3}};\n"
"        \\draw (0.7, 0.3) node {\\encircle{4}};\n"
"      \\end{relcoords}\n"
"    \\end{tikzpicture}\n"
"\n"
"    \\medskip\n"
"    \\footnotesize\n"
"    \\imagecaption{战争机器牌}\n"
"    \\begin{itemize}[itemsep=0pt, parsep=5pt, topsep=0pt, partopsep=0pt]\n"
"      \\item[\\textbf{1.}] 名称\n"
"      \\item[\\textbf{2.}] 效果\n"
"      \\item[\\textbf{3.}] 在战争机器工厂中的费用\n"
"      \\item[\\textbf{4.}] 在贸易站中的费用\n"
"    \\end{itemize}\n"
"  }"
