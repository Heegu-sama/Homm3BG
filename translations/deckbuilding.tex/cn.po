"      \\item[\\textbf{1.}] Name\n"
"      \\item[\\textbf{2.}] Effect\n"
"      \\item[\\textbf{3.}] Cost in a War Machine Factory\n"
"      \\item[\\textbf{4.}] Cost in a Trading Post\n"
"    \\end{itemize}\n"
"  }"
msgstr ""
