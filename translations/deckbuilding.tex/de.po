"        \\draw (0.3, 0.3) node {\\encircle{3}};\n"
"        \\draw (0.7, 0.3) node {\\encircle{4}};\n"
"      \\end{relcoords}\n"
"    \\end{tikzpicture}\n"
"\n"
"    \\medskip\n"
"    \\footnotesize\n"
"    \\imagecaption{Kriegsmaschinenkarte}\n"
