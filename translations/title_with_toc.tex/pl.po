#. type: Plain text
#: sections/title_with_toc.tex:67
msgid ""
"\\AddToHookNext{shipout/background}{\\iftoggle{noartbackground}{}{ \\put "
"(\\iftoggle{printable}{0.05\\paperwidth}"
"{0.03\\paperwidth},-0.75\\paperheight){\\transparent{0.15}"
