msgid ""
"\\iftoggle{githubbuild}{ \\getenv[\\githubsha]{GITHUB_SHA} This is an "
"unreleased version built on GitHub from commit \\href{\\repourl}"
"{\\textlang{english}{\\StrLeft{\\githubsha}{7}}}.  }"
