"        \\draw (0.75, -0.5) node {\\includegraphics[width=0.7\\linewidth]{\\cards/creature-bank.png}};\n"
"      \\end{tikzpicture}\\\\\n"
"      \\imagecaption{Creature Bank unit card}\n"
"    \\end{center}\n"
"  \\end{minipage}\n"
"\n"
msgstr ""
