#: sections/variants.tex:127
#, fuzzy, no-wrap
#| msgid ""
#| "*[before=\\vspace*{-11mm}]{navalbattles}\n"
#| "\\pagetarget{Creature Banks Rules}{\\subheader{Creature Banks}}\n"
#| "\\begin{multicols*}{2}\n"
#| "  Playing with Creature Banks is an \\textbf{optional rule}.\n"
#| "  If you decide to play with Creature Banks, the following rules apply.\n"
#| "\n"
msgid ""
"*[before=\\vspace*{-11mm}]{navalbattles}\n"
"\\pagetarget{Creature Banks Rules}{\\subheader{Creature Banks}}\\index{Creature Banks}\n"
"\\begin{multicols*}{2}\n"
"  Playing with Creature Banks is an \\textbf{optional rule}.\n"
"  If you decide to play with Creature Banks, the following rules apply.\n"
"\n"
msgstr ""
"*[before=\\vspace*{-11mm}]{navalbattles}\n"
"\\pagetarget{Creature Banks Rules}{\\subheader{Kreaturenbanken}}\n"
"  \\begin{multicols*}{2}\n"
"  Kreaturenbanken fügen der Abenteuerkarte neue Orte mit eigenen Kämpfen hinzu.\n"
"  Befolge bei dieser \\textbf{Variante} folgende Regeln:\n"
"\n"

#. type: expansion
#: sections/variants.tex:134
#, no-wrap
msgid ""
"  \\subsection*{Setup}\n"
"  Separate the Creature Bank Tokens into two piles (for Near and Far Map Tiles) based on the numerals on their backs.\n"
"  Shuffle each pile and place them near the Map.\n"
"  Place the Creature Bank unit cards face up near the Neutral Unit Decks.\n"
"  There is no need to shuffle these cards.\n"
"  Shuffle all Stack Tokens and place them near the Creature Bank unit cards.\n"
"\n"
msgstr ""
"  \\subsection*{Vorbereitung}\n"
"  Sortiere die Kreaturenbank-Ortsmarker nach ihrer Rückseite in zwei Stapel (für nahe und ferne Gebiete).\n"
"  Mische beide Stapel und lege sie neben der Abenteuerkarte bereit.\n"
"  Lege die Einheitenkarten für Kreaturenbanken als offenen Stapel bereit.\n"
"  Diese Karten müssen nicht gemischt werden.\n"
"  Mische die Rudelmarker und platziere sie in der Nähe der Kreaturenbank-Einheitenkarten.\n"
"\n"

