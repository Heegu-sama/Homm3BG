#, no-wrap
msgid ""
"*{stretchgoals2}\n"
"  \\begin{multicols*}{2}\n"
"  \\pagetarget{Town Card}{\\subsection*{Town Cards}}\\index{Town cards}\n"
"  You can use Town Cards to randomly choose which player gets which Faction.\n"
"\n"
msgstr ""
"*{stretchgoals2}\n"
"  \\begin{multicols*}{2}\n"
"  \\pagetarget{Town Card}{\\subsection*{Karty Miast}}\\index{Karta Miasta}\n"
"  Dzięki Kartom Miast możesz losowo przydzielać Frakcje graczom.\n"
"\n"

#. type: expansion
#: sections/expansion_content.tex:206
#, no-wrap
msgid ""
