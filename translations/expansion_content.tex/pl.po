"  \\setlength\\intextsep{0pt}\n"
"  \\setlength\\columnsep{0.8em}\n"
"  \\begin{wrapfigure}{l}{0.35\\textwidth}\n"
"    \\includegraphics[width=\\linewidth]{\\boxcovers/stronghold-box.png}\n"
"  \\end{wrapfigure}\n"
